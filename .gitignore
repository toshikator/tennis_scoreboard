# ===== Java / Maven =====
# Build output
/target/

# Maven release / versions plugin files
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# Maven wrapper timing (keep wrapper itself)
.mvn/timing.properties
!/.mvn/wrapper/maven-wrapper.jar

# ===== IDEs =====
# IntelliJ IDEA
.idea/
*.iml
*.iws
out/

# Eclipse
.classpath
.project
.settings/
.bin/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# VS Code
.vscode/

# ===== OS / Misc =====
.DS_Store
Thumbs.db
Desktop.ini

# Temporary / swap / patch leftovers
*.tmp
*.swp
*.swo
*.orig

# JVM crash logs
hs_err_pid*
replay_pid*

# ===== Archives / Artifacts =====
*.war
*.ear

# ===== Logs =====
logs/
*.log

# ===== Properties & Secrets (hide all config files) =====
# Hide all property and YAML files by default
*.properties
*.yml
*.yaml

# Environment files and secrets
.env
.env.*
*.env
*.secret
*.secrets
secrets/

# Allow sample/template configs to be tracked (optional patterns)
!**/*-example.properties
!**/*-example.yml
!**/*-example.yaml
!**/*-sample.properties
!**/*-sample.yml
!**/*-sample.yaml
!**/*.template
!**/*.dist

# If you keep public configuration templates, you can place them as:
#   src/main/resources/application-example.properties
# and commit them (they'll be allowed by the negation rules above).
