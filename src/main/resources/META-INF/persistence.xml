<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.1">
    <persistence-unit name="tennisScoreboardPersistenceUnit" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>pro.bukhman.model.entity.Player</class>
        <class>pro.bukhman.model.entity.Match</class>


        <exclude-unlisted-classes>false</exclude-unlisted-classes>
        <shared-cache-mode>NONE</shared-cache-mode>
        <!--
            JDBC and Hibernate settings are supplied programmatically in HibernateUtil via the second
            parameter of Persistence.createEntityManagerFactory(). You may also move them here if you prefer.
        -->
        <properties>
            <!-- Leave empty to use HibernateUtil's runtime config from app.properties -->
        </properties>
    </persistence-unit>
</persistence>
